# ── IA ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Azure DevOps ─────────────────────────────────────────────────
# Tu organización: https://dev.azure.com/{AZURE_DEVOPS_ORG}
AZURE_DEVOPS_ORG=intempo
# Nombre exacto del proyecto en Azure DevOps
AZURE_DEVOPS_PROJECT=MiProyecto
# Personal Access Token con permisos de Work Items (Read & Write)
# Crear en: https://dev.azure.com/{org}/_usersSettings/tokens
AZURE_DEVOPS_PAT=tu_pat_aqui
# Tipo de work item (por defecto "User Story", ajustar si usan otro)
AZURE_DEVOPS_WORK_ITEM_TYPE=User Story

# ── Servidor ─────────────────────────────────────────────────────
PORT=3001
